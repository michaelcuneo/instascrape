        "share_text": "\u00d0\u0097\u00d0\u0090 \u00d0\u00a2\u00d0\u009e, \u00d0\u00a7\u00d0\u00a2\u00d0\u009e \u00d0\u00af \u00d0\u00a0\u00d0\u0090\u00d0\u00a1\u00d0\u00a1\u00d0\u009a\u00d0\u0090\u00d0\u0096\u00d0\u00a3, \u00d0\u009c\u00d0\u0095\u00d0\u009d\u00d0\u00af \u00d0\u00a0\u00d0\u0090\u00d0\u0097\u00d0\u009e\u00d0\u00a0\u00d0\u0092\u00d0\u00a3\u00d0\u00a2 \u00d0\u0092\u00d0\u00a1\u00d0\u0095 \u00d0\u00ad\u00d0\u009a\u00d0\u00a1\u00d0\u009f\u00d0\u0095\u00d0\u00a0\u00d0\u00a2\u00d0\u00ab!\u00f0\u009f\u0098\u0085\n\u00e2\u00a0\u0080\n\u00d0\u009a\u00d0\u00b0\u00d0\u00ba \u00d1\u0082\u00d1\u008b \u00d0\u00b4\u00d1\u0083\u00d0\u00bc\u00d0\u00b0\u00d0\u00b5\u00d1\u0088\u00d1\u008c, \u00d1\u0081\u00d0\u00ba\u00d0\u00be\u00d0\u00bb\u00d1\u008c\u00d0\u00ba\u00d0\u00be \u00d0\u00bf\u00d0\u00be\u00d1\u0081\u00d1\u0082\u00d0\u00be\u00d0\u00b2 \u00d0\u00bd\u00d0\u00b0\u00d0\u00b4\u00d0\u00be \u00d0\u00bf\u00d0\u00b8\u00d1\u0081\u00d0\u00b0\u00d1\u0082\u00d1\u008c \u00d0\u00b2 \u00d0\u00bd\u00d0\u00b5\u00d0\u00b4\u00d0\u00b5\u00d0\u00bb\u00d1\u008e \u00d0\u00b4\u00d0\u00bb\u00d1\u008f \u00d0\u0098\u00d0\u00bd\u00d1\u0081\u00d1\u0082\u00d0\u00b0\u00d0\u00b3\u00d1\u0080\u00d0\u00b0\u00d0\u00bc, \u00d1\u0087\u00d1\u0082\u00d0\u00be\u00d0\u00b1\u00d1\u008b \u00d0\u00bf\u00d1\u0080\u00d0\u00be\u00d0\u00b4\u00d0\u00be\u00d0\u00bb\u00d0\u00b6\u00d0\u00b0\u00d0\u00bb\u00d1\u0081\u00d1\u008f, \u00d0\u00b8\u00d0\u00bb\u00d0\u00b8 \u00d0\u00bd\u00d0\u00b0\u00d1\u0087\u00d0\u00b0\u00d0\u00bb\u00d1\u0081\u00d1\u008f \u00d0\u00bf\u00d1\u0080\u00d0\u00b8\u00d1\u0082\u00d0\u00be\u00d0\u00ba \u00d0\u00ba\u00d0\u00bb\u00d0\u00b8\u00d0\u00b5\u00d0\u00bd\u00d1\u0082\u00d0\u00be\u00d0\u00b2?\n\u00e2\u00a0\u0080\n\u00d0\u009c\u00d0\u00b5\u00d0\u00bd\u00d1\u008f \u00d0\u00b8\u00d0\u00bd\u00d0\u00be\u00d0\u00b3\u00d0\u00b4\u00d0\u00b0 \u00d1\u0081\u00d0\u00bf\u00d1\u0080\u00d0\u00b0\u00d1\u0088\u00d0\u00b8\u00d0\u00b2\u00d0\u00b0\u00d1\u008e\u00d1\u0082: \u00d1\u0082\u00d1\u008b \u00d0\u00bf\u00d0\u00be\u00d0\u00b7\u00d0\u00b2\u00d0\u00be\u00d0\u00bb\u00d1\u008f\u00d0\u00b5\u00d1\u0088\u00d1\u008c \u00d1\u0081\u00d0\u00b5\u00d0\u00b1\u00d0\u00b5 \u00d0\u00b2\u00d1\u008b\u00d0\u00bf\u00d0\u00b0\u00d0\u00b4\u00d0\u00b0\u00d1\u0082\u00d1\u008c \u00d0\u00b8\u00d0\u00b7 \u00d1\u0081\u00d0\u00b5\u00d1\u0082\u00d0\u00b8 \u00d0\u00bd\u00d0\u00b0 \u00d0\u00bd\u00d0\u00b5\u00d0\u00b4\u00d0\u00b5\u00d0\u00bb\u00d1\u008e, \u00d0\u00b8 \u00d1\u0087\u00d1\u0082\u00d0\u00be, \u00d1\u008d\u00d1\u0082\u00d0\u00be \u00d0\u00bd\u00d0\u00b8\u00d0\u00ba\u00d0\u00b0\u00d0\u00ba \u00d0\u00bd\u00d0\u00b5 \u00d0\u00b2\u00d0\u00bb\u00d0\u00b8\u00d1\u008f\u00d0\u00b5\u00d1\u0082 \u00d0\u00bd\u00d0\u00b0 \u00d0\u00bf\u00d1\u0080\u00d0\u00b8\u00d1\u0085\u00d0\u00be\u00d0\u00b4 \u00d0\u00b8\u00d0\u00b7 \u00d0\u0098\u00d0\u00bd\u00d1\u0081\u00d1\u0082\u00d0\u00b0\u00d0\u00b3\u00d1\u0080\u00d0\u00b0\u00d0\u00bc\u00d0\u00b0 \u00d0\u00ba\u00d0\u00bb\u00d0\u00b8\u00d0\u00b5\u00d0\u00bd\u00d1\u0082\u00d0\u00be\u00d0\u00b2?\n\u00e2\u00a0\u0080\n\u00d0\u00a0\u00d0\u00b5\u00d0\u00b0\u00d0\u00bb\u00d1\u008c\u00d0\u00bd\u00d0\u00be. \u00d0\u00af \u00d0\u00bc\u00d0\u00be\u00d0\u00b3\u00d1\u0083 \u00d0\u00bd\u00d0\u00b5 \u00d0\u00b2\u00d1\u008b\u00d0\u00ba\u00d0\u00bb\u00d0\u00b0\u00d0\u00b4\u00d1\u008b\u00d0\u00b2\u00d0\u00b0\u00d1\u0082\u00d1\u008c \u00d0\u00bf\u00d0\u00be\u00d1\u0081\u00d1\u0082\u00d1\u008b \u00d0\u00b8\u00d0\u00bb\u00d0\u00b8 \u00d0\u00a1\u00d1\u0082\u00d0\u00be\u00d1\u0080\u00d0\u00b8\u00d1\u0081, \u00d0\u00bd\u00d0\u00b5 \u00d0\u00bf\u00d0\u00b0\u00d1\u0080\u00d0\u00b8\u00d1\u0082\u00d1\u008c\u00d1\u0081\u00d1\u008f \u00d0\u00b7\u00d0\u00b0 \u00d0\u00be\u00d1\u0085\u00d0\u00b2\u00d0\u00b0\u00d1\u0082\u00d1\u008b \u00d0\u00b8 \u00d0\u00b2\u00d1\u0081\u00d0\u00b5 \u00d1\u008d\u00d1\u0082\u00d0\u00be \u00d0\u00bf\u00d0\u00be \u00d0\u00bd\u00d0\u00b5\u00d1\u0081\u00d0\u00ba\u00d0\u00be\u00d0\u00bb\u00d1\u008c\u00d0\u00ba\u00d1\u0083 \u00d0\u00b4\u00d0\u00bd\u00d0\u00b5\u00d0\u00b9 \u00d0\u00b8\u00d0\u00bb\u00d0\u00b8 \u00d0\u00bd\u00d0\u00b5\u00d0\u00b4\u00d0\u00b5\u00d0\u00bb\u00d1\u008c \u00d0\u00bf\u00d0\u00be\u00d0\u00b4\u00d1\u0080\u00d1\u008f\u00d0\u00b4, \u00d0\u00b8 \u00d0\u00ba\u00d0\u00b0\u00d0\u00ba \u00d1\u0082\u00d1\u008b \u00d0\u00b4\u00d1\u0083\u00d0\u00bc\u00d0\u00b0\u00d0\u00b5\u00d1\u0088\u00d1\u008c \u00d1\u0083\u00d0\u00b1\u00d0\u00b0\u00d0\u00b2\u00d0\u00b8\u00d0\u00bb\u00d0\u00be\u00d1\u0081\u00d1\u008c \u00d0\u00bb\u00d0\u00b8 \u00d1\u0083 \u00d0\u00bc\u00d0\u00b5\u00d0\u00bd\u00d1\u008f \u00d0\u00ba\u00d0\u00bb\u00d0\u00b8\u00d0\u00b5\u00d0\u00bd\u00d1\u0082\u00d0\u00be\u00d0\u00b2?\n\u00e2\u00a0\u0080\n\u00d0\u009f\u00d0\u00be \u00d0\u00b8\u00d0\u00bd\u00d1\u0082\u00d0\u00be\u00d0\u00bd\u00d0\u00b0\u00d1\u0086\u00d0\u00b8\u00d0\u00b8 \u00d1\u008d\u00d1\u0082\u00d0\u00be\u00d0\u00b3\u00d0\u00be \u00d1\u0082\u00d0\u00b5\u00d0\u00ba\u00d1\u0081\u00d1\u0082\u00d0\u00b0 \u00d0\u00bf\u00d0\u00be\u00d0\u00bd\u00d1\u008f\u00d1\u0082\u00d0\u00bd\u00d0\u00be, \u00d1\u0087\u00d1\u0082\u00d0\u00be \u00d0\u00bd\u00d0\u00b5\u00d1\u0082. \u00d0\u00a2\u00d1\u008b \u00d0\u00b7\u00d1\u0080\u00d1\u008f \u00d0\u00bf\u00d0\u00b0\u00d1\u0080\u00d0\u00b8\u00d1\u0088\u00d1\u008c\u00d1\u0081\u00d1\u008f \u00d0\u00b2\u00d1\u008b\u00d0\u00b6\u00d0\u00b8\u00d0\u00b3\u00d0\u00b0\u00d1\u008f \u00d1\u0081\u00d0\u00b5\u00d0\u00b1\u00d1\u008f \u00d1\u0082\u00d0\u00be\u00d0\u00bd\u00d0\u00bd\u00d0\u00b0\u00d0\u00bc\u00d0\u00b8 \u00d0\u00ba\u00d0\u00be\u00d0\u00bd\u00d1\u0082\u00d0\u00b5\u00d0\u00bd\u00d1\u0082\u00d0\u00b0. \u00d0\u00a2\u00d1\u008b - \u00d1\u008d\u00d0\u00ba\u00d1\u0081\u00d0\u00bf\u00d0\u00b5\u00d1\u0080\u00d1\u0082 - \u00d1\u0082\u00d0\u00b5\u00d0\u00b1\u00d0\u00b5 \u00d0\u00b5\u00d0\u00b3\u00d0\u00be \u00d0\u00b2\u00d0\u00be\u00d0\u00be\u00d0\u00b1\u00d1\u0089\u00d0\u00b5 \u00d1\u0082\u00d0\u00be\u00d0\u00bb\u00d0\u00ba\u00d0\u00be\u00d0\u00bc \u00d0\u00b4\u00d0\u00b5\u00d0\u00bb\u00d0\u00b0\u00d1\u0082\u00d1\u008c \u00d0\u00bd\u00d0\u00b5 \u00d0\u00be\u00d0\u00b1\u00d1\u008f\u00d0\u00b7\u00d0\u00b0\u00d1\u0082\u00d0\u00b5\u00d0\u00bb\u00d1\u008c\u00d0\u00bd\u00d0\u00be. \u00d0\u0093\u00d0\u00bb\u00d0\u00b0\u00d0\u00b2\u00d0\u00bd\u00d0\u00be\u00d0\u00b5 \u00d0\u00bf\u00d0\u00be\u00d0\u00bf\u00d0\u00b0\u00d0\u00b4\u00d0\u00b0\u00d1\u0082\u00d1\u008c \u00d1\u0081\u00d0\u00bc\u00d1\u008b\u00d1\u0081\u00d0\u00bb\u00d0\u00b0\u00d0\u00bc\u00d0\u00b8 \u00d0\u00b2 \u00d0\u00b7\u00d0\u00b0\u00d0\u00bf\u00d1\u0080\u00d0\u00be\u00d1\u0081\u00d1\u008b \u00d0\u00b0\u00d1\u0083\u00d0\u00b4\u00d0\u00b8\u00d1\u0082\u00d0\u00be\u00d1\u0080\u00d0\u00b8\u00d0\u00b8, \u00d0\u00b2\u00d1\u008b\u00d1\u0080\u00d0\u00b0\u00d1\u0081\u00d1\u0082\u00d0\u00b8\u00d1\u0082\u00d1\u008c \u00d0\u00bf\u00d0\u00be\u00d1\u0082\u00d1\u0080\u00d0\u00b5\u00d0\u00b1\u00d0\u00bd\u00d0\u00be\u00d1\u0081\u00d1\u0082\u00d1\u008c \u00d0\u00b2 \u00d1\u0081\u00d0\u00b5\u00d0\u00b1\u00d0\u00b5, \u00d0\u00b8 \u00d0\u00bd\u00d0\u00b0\u00d0\u00b1\u00d1\u0080\u00d0\u00b0\u00d1\u0082\u00d1\u008c \u00d0\u00ba\u00d0\u00bb\u00d0\u00b8\u00d0\u00b5\u00d0\u00bd\u00d1\u0082\u00d0\u00be\u00d0\u00b2. \u00d0\u00a2\u00d1\u008b - \u00d0\u00bd\u00d0\u00b5 \u00d0\u00b1\u00d0\u00bb\u00d0\u00be\u00d0\u00b3\u00d0\u00b5\u00d1\u0080.\n\u00e2\u00a0\u0080\n\u00d0\u0094\u00d0\u00be\u00d1\u0081\u00d1\u0082\u00d0\u00b0\u00d1\u0082\u00d0\u00be\u00d1\u0087\u00d0\u00bd\u00d0\u00be \u00d0\u00bd\u00d0\u00b0\u00d0\u00bf\u00d0\u00b8\u00d1\u0081\u00d0\u00b0\u00d1\u0082\u00d1\u008c 1 \u00d0\u00bf\u00d0\u00be\u00d1\u0081\u00d1\u0082 \u00d1\u0080\u00d0\u00b0\u00d0\u00b7 \u00d0\u00b2 2 (!!!!) \u00d0\u00bd\u00d0\u00b5\u00d0\u00b4\u00d0\u00b5\u00d0\u00bb\u00d0\u00b8 - \u00d0\u00b1\u00d0\u00be\u00d0\u00bb\u00d1\u008c\u00d1\u0088\u00d0\u00b5 \u00d1\u0083\u00d0\u00b6\u00d0\u00b5 \u00d0\u00b8 \u00d1\u0081\u00d0\u00bc\u00d1\u008b\u00d1\u0081\u00d0\u00bb\u00d0\u00b0 \u00d0\u00bd\u00d0\u00b5\u00d1\u0082, \u00d0\u00bf\u00d0\u00be\u00d1\u0082\u00d0\u00be\u00d0\u00bc\u00d1\u0083 \u00d1\u0087\u00d1\u0082\u00d0\u00be \u00d0\u00b2\u00d1\u0081\u00d1\u008f \u00d0\u00bb\u00d0\u00b5\u00d0\u00bd\u00d1\u0082\u00d0\u00b0 \u00d0\u00b2 \u00d0\u00a0\u00d0\u00b8\u00d0\u00bb\u00d1\u0081\u00d0\u00b0\u00d1\u0085 - \u00d0\u00b8 \u00d0\u00be\u00d0\u00bd \u00d0\u00b1\u00d1\u0083\u00d0\u00b4\u00d0\u00b5\u00d1\u0082 \u00d0\u00bf\u00d1\u0080\u00d0\u00b8\u00d0\u00bd\u00d0\u00be\u00d1\u0081\u00d0\u00b8\u00d1\u0082\u00d1\u008c \u00d1\u0082\u00d0\u00b5\u00d0\u00b1\u00d0\u00b5 \u00d0\u00ba\u00d0\u00bb\u00d0\u00b8\u00d0\u00b5\u00d0\u00bd\u00d1\u0082\u00d0\u00be\u00d0\u00b2, \u00d0\u00b7\u00d0\u00b0\u00d0\u00bf\u00d0\u00b8\u00d1\u0081\u00d0\u00b8 \u00d0\u00bd\u00d0\u00b0 \u00d0\u00ba\u00d0\u00be\u00d0\u00bd\u00d1\u0081\u00d1\u0083\u00d0\u00bb\u00d1\u008c\u00d1\u0082\u00d0\u00b0\u00d1\u0086\u00d0\u00b8\u00d0\u00b8 \u00d0\u00b8\u00d0\u00bb\u00d0\u00b8 \u00d1\u0083\u00d1\u0081\u00d0\u00bb\u00d1\u0083\u00d0\u00b3\u00d0\u00b8. \u00d0\u009e\u00d0\u0094\u00d0\u009d\u00d0\u009e \u00d0\u00a3\u00d0\u00a1\u00d0\u009b\u00d0\u009e\u00d0\u0092\u00d0\u0098\u00d0\u0095: \u00d0\u00be\u00d0\u00bd \u00d0\u00b3\u00d1\u0080\u00d0\u00b0\u00d0\u00bc\u00d0\u00be\u00d1\u0082\u00d0\u00bd\u00d0\u00be \u00d1\u0081\u00d0\u00ba\u00d0\u00be\u00d0\u00bd\u00d1\u0081\u00d1\u0082\u00d1\u0080\u00d1\u0083\u00d0\u00b8\u00d1\u0080\u00d0\u00be\u00d0\u00b2\u00d0\u00b0\u00d0\u00bd \u00d0\u00b8 \u00d0\u00b1\u00d1\u008c\u00d0\u00b5\u00d1\u0082 \u00d0\u00b2 \u00d0\u00bf\u00d0\u00be\u00d1\u0082\u00d1\u0080\u00d0\u00b5\u00d0\u00b1\u00d0\u00bd\u00d0\u00be\u00d1\u0081\u00d1\u0082\u00d1\u008c.\n\u00e2\u00a0\u0080\n\u00d0\u00a7\u00d0\u00a2\u00d0\u009e \u00d0\u0095\u00d0\u00a1\u00d0\u009b\u00d0\u0098 \u00d0\u0091\u00d0\u00ab \u00d0\u00a3 \u00d0\u00a2\u00d0\u0095\u00d0\u0091\u00d0\u00af \u00d0\u0091\u00d0\u00ab\u00d0\u009b \u00d0\u00a2\u00d0\u009e\u00d0\u00a2 \u00d0\u00a1\u00d0\u0090\u00d0\u009c\u00d0\u00ab\u00d0\u0099 \u00d0\u009f\u00d0\u009e\u00d0\u00a1\u00d0\u00a2? \u00d0\u00a1\u00d0\u00bc.\u00d0\u00ba\u00d0\u00b0\u00d1\u0080\u00d1\u0083\u00d1\u0081\u00d0\u00b5\u00d0\u00bb\u00d1\u008c\n\u00d0\u00af \u00d0\u00bf\u00d0\u00be\u00d0\u00ba\u00d0\u00b0\u00d0\u00b6\u00d1\u0083 \u00d1\u0082\u00d0\u00b5\u00d0\u00b1\u00d0\u00b5 \u00d0\u00ba\u00d0\u00b0\u00d1\u0080\u00d0\u00ba\u00d0\u00b0\u00d1\u0081 \u00d1\u0082\u00d0\u00b0\u00d0\u00ba\u00d0\u00be\u00d0\u00b3\u00d0\u00be \u00d1\u0082\u00d0\u00b5\u00d0\u00ba\u00d1\u0081\u00d1\u0082\u00d0\u00b0:\n\u00e2\u00a0\u0080\n1. \u00d0\u0098\u00d0\u00bd\u00d1\u0082\u00d1\u0080\u00d0\u00b8\u00d0\u00b3\u00d1\u0083\u00d1\u008e\u00d1\u0089\u00d0\u00b0\u00d1\u008f \u00d1\u0082\u00d0\u00b5\u00d0\u00bc\u00d0\u00b0\n2. \u00d0\u00af\u00d0\u00ba\u00d0\u00be\u00d1\u0080\u00d1\u008c \u00d0\u00bd\u00d0\u00b0 \"\u00d0\u00b6\u00d0\u00b8\u00d0\u00b7\u00d0\u00b5\"\n3.  \u00d0\u00a0\u00d0\u00b0\u00d0\u00b7\u00d0\u00b2\u00d0\u00b8\u00d1\u0082\u00d0\u00b8\u00d0\u00b5\n4. \u00d0\u009f\u00d0\u00be\u00d1\u008f\u00d1\u0081\u00d0\u00bd\u00d1\u008f\u00d0\u00b5\u00d0\u00bc \u00d1\u0081\u00d0\u00b8\u00d1\u0082\u00d1\u0083\u00d0\u00b0\u00d1\u0086\u00d0\u00b8\u00d1\u008e\n5. \u00d0\u009f\u00d1\u0080\u00d0\u00be\u00d0\u00b3\u00d0\u00be\u00d0\u00b2\u00d0\u00b0\u00d1\u0080\u00d0\u00b8\u00d0\u00b2\u00d0\u00b0\u00d0\u00b5\u00d0\u00bc \u00d0\u00bf\u00d0\u00b0\u00d1\u0082\u00d1\u0082\u00d0\u00b5\u00d1\u0080\u00d0\u00bd\u00d1\u008b\u00e2\u0080\u00a6\n6. \u00e2\u0080\u00a6\n7. \u00e2\u0080\u00a6\n8. \u00e2\u0080\u00a6\n\u00d0\u009d\u00d0\u00b5 \u00d1\u0085\u00d0\u00be\u00d1\u0087\u00d1\u0083 \u00d0\u00b2\u00d1\u0081\u00d0\u00b5\u00d0\u00bc \u00d1\u0082\u00d1\u0083\u00d1\u0082 \u00d0\u00be\u00d1\u0081\u00d0\u00b2\u00d0\u00b5\u00d1\u0089\u00d0\u00b0\u00d1\u0082\u00d1\u008c\u00f0\u009f\u00a4\u00ab\n\u00e2\u00a0\u0080\n\u00d0\u009a\u00d0\u00be\u00d0\u00b3\u00d0\u00b4\u00d0\u00b0 \u00d1\u008f \u00d0\u00b1\u00d1\u008b\u00d0\u00bb\u00d0\u00b0 \u00d0\u00bf\u00d1\u0080\u00d0\u00be\u00d0\u00b4\u00d1\u008e\u00d1\u0081\u00d0\u00b5\u00d1\u0080\u00d0\u00be\u00d0\u00bc \u00d0\u00b2\u00d0\u00b5\u00d0\u00b1\u00d0\u00b8\u00d0\u00bd\u00d0\u00b0\u00d1\u0080\u00d1\u008b, \u00d1\u0081\u00d0\u00be\u00d0\u00b7\u00d0\u00b4\u00d0\u00b0\u00d0\u00bd\u00d0\u00b8\u00d0\u00b5 \u00d1\u0082\u00d0\u00be\u00d0\u00bd\u00d0\u00bd \u00d0\u00ba\u00d0\u00be\u00d0\u00bd\u00d1\u0082\u00d0\u00b5\u00d0\u00bd\u00d1\u0082\u00d0\u00b0 \u00d0\u00b8 \u00d0\u00bf\u00d0\u00be\u00d0\u00bb\u00d0\u00bd\u00d0\u00b0\u00d1\u008f \u00d0\u00bf\u00d1\u0080\u00d0\u00be\u00d1\u0081\u00d1\u0082\u00d1\u0080\u00d0\u00b0\u00d1\u0086\u00d0\u00b8\u00d1\u008f \u00d0\u00b2 \u00d1\u0080\u00d0\u00b0\u00d1\u0081\u00d1\u0084\u00d0\u00be\u00d0\u00ba\u00d1\u0083\u00d1\u0081\u00d0\u00b5 \u00d0\u00b2\u00d1\u008b\u00d0\u00b6\u00d0\u00b3\u00d0\u00bb\u00d0\u00b8 \u00d0\u00bc\u00d0\u00b5\u00d0\u00bd\u00d1\u008f.\n\u00d0\u00af \u00d0\u00b1\u00d1\u008b\u00d0\u00bb\u00d0\u00b0 \u00d0\u00b2 \u00d0\u00b4\u00d0\u00b5\u00d0\u00bf\u00d1\u0080\u00d0\u00b5\u00d1\u0081\u00d0\u00b8\u00d0\u00b8 \u00d0\u00bf\u00d0\u00be\u00d0\u00bb \u00d0\u00b3\u00d0\u00be\u00d0\u00b4\u00d0\u00b0. \u00d0\u0091\u00d0\u00b5\u00d0\u00b7 \u00d1\u0081\u00d0\u00b8\u00d0\u00bb, \u00d0\u00bd\u00d0\u00be \u00d1\u0081 \u00d0\u00bd\u00d0\u00b0\u00d0\u00b2\u00d1\u008b\u00d0\u00ba\u00d0\u00be\u00d0\u00bc \u00d0\u00b8 \u00d0\u00be\u00d1\u0085\u00d0\u00b8\u00d1\u0080\u00d0\u00b5\u00d0\u00bd\u00d0\u00bd\u00d1\u008b\u00d0\u00bc \u00d0\u00be\u00d0\u00bf\u00d1\u008b\u00d1\u0082\u00d0\u00be\u00d0\u00bc. \u00d0\u00a1\u00d0\u00b5\u00d0\u00b9\u00d1\u0087\u00d0\u00b0\u00d1\u0081 \u00d0\u00bc\u00d0\u00bd\u00d0\u00b5 \u00d1\u0082\u00d1\u008f\u00d0\u00b6\u00d0\u00b5\u00d0\u00bb\u00d0\u00be \u00d1\u0080\u00d0\u00b0\u00d0\u00b1\u00d0\u00be\u00d1\u0082\u00d0\u00b0\u00d1\u0082\u00d1\u008c \u00d1\u0081 \u00d0\u00b1\u00d0\u00be\u00d0\u00bb\u00d1\u008c\u00d1\u0088\u00d0\u00b8\u00d0\u00bc\u00d0\u00b8 \u00d0\u00b3\u00d1\u0080\u00d1\u0083\u00d0\u00bf\u00d0\u00bf\u00d0\u00b0\u00d0\u00bc\u00d0\u00b8 \u00d0\u00bb\u00d1\u008e\u00d0\u00b4\u00d0\u00b5\u00d0\u00b9. \u00d0\u00af \u00d0\u00bd\u00d0\u00b5 \u00d1\u0085\u00d0\u00be\u00d1\u0087\u00d1\u0083 \u00d0\u00b2\u00d0\u00b5\u00d1\u0081\u00d1\u0082\u00d0\u00b8 \u00d0\u00b2\u00d0\u00b5\u00d0\u00b1\u00d0\u00b8\u00d0\u00bd\u00d0\u00b0\u00d1\u0080\u00d1\u008b \u00d0\u00b8 \u00d0\u00bf\u00d1\u0080\u00d0\u00be\u00d0\u00b4\u00d0\u00b0\u00d0\u00b2\u00d0\u00b0\u00d1\u0082\u00d1\u008c \u00d1\u0081\u00d0\u00b5\u00d0\u00b1\u00d1\u008f, \u00d0\u00bf\u00d0\u00be\u00d1\u0082\u00d0\u00be\u00d0\u00bc\u00d1\u0083 \u00d1\u0087\u00d1\u0082\u00d0\u00be \u00d1\u008d\u00d1\u0082\u00d0\u00be \u00d0\u00b6\u00d1\u0080\u00d0\u00b5\u00d1\u0082 \u00d0\u00bc\u00d0\u00be\u00d1\u008e \u00d1\u008d\u00d0\u00bd\u00d0\u00b5\u00d1\u0080\u00d0\u00b3\u00d0\u00b8\u00d1\u008e, \u00d0\u00ba\u00d0\u00b0\u00d0\u00ba \u00d0\u00bd\u00d0\u00b0\u00d1\u0081\u00d1\u0082\u00d0\u00b0\u00d0\u00b2\u00d0\u00bd\u00d0\u00b8\u00d0\u00ba\u00d0\u00b0.\n\u00e2\u00a0\u0080\n\u00d0\u009f\u00d0\u00be\u00d1\u008d\u00d1\u0082\u00d0\u00be\u00d0\u00bc\u00d1\u0083 \u00d1\u008f \u00d0\u00b4\u00d0\u00b5\u00d0\u00bb\u00d0\u00b0\u00d1\u008e \u00d1\u0082\u00d0\u00b0\u00d0\u00ba, \u00d1\u0087\u00d1\u0082\u00d0\u00be\u00d0\u00b1\u00d1\u008b \u00d1\u0081\u00d0\u00b8\u00d1\u0081\u00d1\u0082\u00d0\u00b5\u00d0\u00bc\u00d0\u00b0 \u00d0\u00ba\u00d0\u00be\u00d0\u00bd\u00d1\u0082\u00d0\u00b5\u00d0\u00bd\u00d1\u0082\u00d0\u00b0 \u00d0\u00bf\u00d1\u0080\u00d0\u00be\u00d0\u00b4\u00d0\u00b0\u00d0\u00b2\u00d0\u00b0\u00d0\u00bb\u00d0\u00b0 \u00d0\u00b7\u00d0\u00b0 \u00d0\u00bc\u00d0\u00b5\u00d0\u00bd\u00d1\u008f.\n\u00e2\u00a0\u0080\n\u00d0\u009b\u00d1\u008e\u00d0\u00b4\u00d0\u00b5\u00d0\u00b9 \u00d0\u00bc\u00d0\u00b5\u00d0\u00bd\u00d1\u008c\u00d1\u0088\u00d0\u00b5. \u00d0\u009c\u00d0\u00b5\u00d0\u00bd\u00d1\u008c\u00d1\u0088\u00d0\u00b5 \u00d1\u0080\u00d0\u00b0\u00d0\u00b1\u00d0\u00be\u00d1\u0082\u00d1\u008b. \u00d0\u009c\u00d0\u00b5\u00d0\u00bd\u00d1\u008c\u00d1\u0088\u00d0\u00b5 \u00d0\u00ba\u00d0\u00be\u00d0\u00bd\u00d1\u0082\u00d0\u00b5\u00d0\u00bd\u00d1\u0082\u00d0\u00b0.\n\n\u00e2\u00a0\u0080\u00d0\u00a1\u00d1\u0085\u00d0\u00b5\u00d0\u00bc\u00d0\u00b0 \u00d0\u00b2\u00d0\u00be\u00d1\u0082: \n\u00e2\u00a0\u0080\n\u00f0\u009f\u0091\u0089\u00f0\u009f\u008f\u00bb\u00d0\u0097\u00d0\u00b0\u00d1\u0085\u00d0\u00b2\u00d0\u00b0\u00d1\u0082 \u00d0\u00b2\u00d0\u00bd\u00d0\u00b8\u00d0\u00bc\u00d0\u00b0\u00d0\u00bd\u00d0\u00b8\u00d1\u008f- \u00d1\u0086\u00d0\u00b5\u00d0\u00bd\u00d0\u00bd\u00d0\u00be\u00d1\u0081\u00d1\u0082\u00d1\u008c \u00d1\u0081\u00d1\u0080\u00d0\u00b0\u00d0\u00b7\u00d1\u0083 - \u00d1\u008d\u00d0\u00ba\u00d1\u0081\u00d0\u00bf\u00d0\u00b5\u00d1\u0080\u00d1\u0082\u00d0\u00bd\u00d1\u008b\u00d0\u00b9 \u00d0\u00b0\u00d0\u00b2\u00d1\u0082\u00d0\u00be\u00d1\u0080\u00d0\u00b8\u00d1\u0082\u00d0\u00b5\u00d1\u0082\n\u00e2\u00a0\u0080\n\u00d0\u00ad\u00d1\u0082\u00d0\u00be \u00d0\u00bc\u00d0\u00be\u00d0\u00b9 \u00d0\u00bc\u00d0\u00b5\u00d1\u0082\u00d0\u00be\u00d0\u00b4. \u00f0\u009f\u00a4\u009a\u00f0\u009f\u008f\u00bb 1 \u00d0\u00bf\u00d1\u0083\u00d0\u00bd\u00d0\u00ba\u00d1\u0082 \u00d1\u008f \u00d0\u00b7\u00d0\u00b0\u00d0\u00ba\u00d1\u0080\u00d1\u008b\u00d0\u00b2\u00d0\u00b0\u00d1\u008e \u00d1\u0082\u00d0\u00b5\u00d0\u00bc, \u00d1\u0087\u00d1\u0082\u00d0\u00be \u00d0\u00bf\u00d0\u00b8\u00d1\u0088\u00d1\u0083 \u00d0\u00bf\u00d0\u00be\u00d1\u0081\u00d1\u0082, \u00d1\u0081 \u00d0\u00ba\u00d0\u00be\u00d1\u0082\u00d0\u00be\u00d1\u0080\u00d0\u00be\u00d0\u00b3\u00d0\u00be \u00d0\u00a2\u00d0\u009e\u00d0\u00a7\u00d0\u009d\u00d0\u009e \u00d0\u0098\u00d0\u0094\u00d0\u00a3\u00d0\u00a2 \u00d0\u00b2 \u00d0\u00ba\u00d0\u00be\u00d0\u00bd\u00d1\u0081\u00d1\u0083\u00d0\u00bb\u00d1\u008c\u00d1\u0082\u00d0\u00b0\u00d1\u0086\u00d0\u00b8\u00d1\u008e.\n\u00e2\u00a0\u0080\n\u00d0\u00af \u00d0\u00bf\u00d1\u0080\u00d0\u00b8\u00d0\u00b3\u00d0\u00be\u00d1\u0082\u00d0\u00be\u00d0\u00b2\u00d0\u00b8\u00d0\u00bb\u00d0\u00b0 \u00d0\u00b4\u00d0\u00bb\u00d1\u008f \u00d1\u0082\u00d0\u00b5\u00d0\u00b1\u00d1\u008f \u00d0\u00be\u00d1\u0087\u00d0\u00b5\u00d0\u00bd\u00d1\u008c \u00d0\u00b6\u00d0\u00b5\u00d0\u00bb\u00d0\u00b0\u00d0\u00bd\u00d0\u00bd\u00d1\u008b\u00d0\u00b9 pdf-\u00d1\u0084\u00d0\u00b0\u00d0\u00b9\u00d0\u00bb \u00e2\u0080\u009c\u00d0\u00a8\u00d0\u00b0\u00d0\u00b1\u00d0\u00bb\u00d0\u00be\u00d0\u00bd \u00d0\u00bf\u00d0\u00be\u00d1\u0081\u00d1\u0082\u00d0\u00b0\u00c2\u00bb. \u00d0\u009e\u00d0\u00bd \u00d0\u00b4\u00d0\u00bb\u00d1\u008f \u00d1\u0082\u00d0\u00be\u00d0\u00b3\u00d0\u00be, \u00d1\u0087\u00d1\u0082\u00d0\u00be\u00d0\u00b1\u00d1\u008b \u00d0\u00b2 \u00d0\u00bb\u00d1\u008e\u00d0\u00b1\u00d0\u00be\u00d0\u00b5 \u00d0\u00b2\u00d1\u0080\u00d0\u00b5\u00d0\u00bc\u00d1\u008f \u00d0\u00b8\u00d0\u00bc\u00d0\u00b5\u00d1\u0082\u00d1\u008c \u00d0\u00bf\u00d0\u00be\u00d0\u00b4 \u00d1\u0080\u00d1\u0083\u00d0\u00ba\u00d0\u00be\u00d0\u00b9 \u00d0\u00ba\u00d0\u00be\u00d0\u00bd\u00d1\u0081\u00d1\u0082\u00d1\u0080\u00d1\u0083\u00d0\u00ba\u00d1\u0082\u00d0\u00be\u00d1\u0080 \u00d1\u0081\u00d0\u00bc\u00d1\u008b\u00d1\u0081\u00d0\u00bb\u00d0\u00be\u00d0\u00b2 \u00d0\u00b4\u00d0\u00bb\u00d1\u008f \u00d0\u00bf\u00d0\u00be\u00d1\u0081\u00d1\u0082\u00d0\u00b0, \u00d1\u0081 \u00d0\u00ba\u00d0\u00be\u00d1\u0082\u00d0\u00be\u00d1\u0080\u00d0\u00be\u00d0\u00b3\u00d0\u00be \u00d1\u0082\u00d1\u008b \u00d0\u00bf\u00d1\u0080\u00d0\u00be\u00d0\u00b4\u00d0\u00b0\u00d0\u00b5\u00d1\u0088\u00d1\u008c \u00d0\u00ba\u00d0\u00be\u00d0\u00bd\u00d1\u0081\u00d1\u0083\u00d0\u00bb\u00d1\u008c\u00d1\u0082\u00d0\u00b0\u00d1\u0086\u00d0\u00b8\u00d1\u008e \u00d0\u00b8 \u00d0\u00bb\u00d0\u00b8 \u00d0\u00b1\u00d0\u00b5\u00d1\u0081\u00d0\u00bf\u00d0\u00bb\u00d0\u00b0\u00d1\u0082\u00d0\u00bd\u00d1\u0083\u00d1\u008e \u00d0\u00b4\u00d0\u00b8\u00d0\u00b0\u00d0\u00b3\u00d0\u00bd\u00d0\u00be\u00d1\u0081\u00d1\u0082\u00d0\u00b8\u00d0\u00ba\u00d1\u0083. \u00d0\u0094\u00d0\u00bb\u00d1\u008f \u00d1\u0083\u00d1\u0081\u00d1\u0082\u00d0\u00b0\u00d0\u00bd\u00d0\u00be\u00d0\u00b2\u00d0\u00bb\u00d0\u00b5\u00d0\u00bd\u00d0\u00b8\u00d1\u008f \u00d0\u00ba\u00d0\u00be\u00d0\u00bd\u00d1\u0082\u00d0\u00b0\u00d0\u00ba\u00d1\u0082\