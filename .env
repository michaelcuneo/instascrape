# Target account credentials (where content is uploaded)
INSTAGRAM_USERNAME=theoakth
INSTAGRAM_PASSWORD=S0ci@lInfluencer!

# Source account in the backup export (used for comment-owner matching)
SOURCE_ACCOUNT_USERNAME=theoak.tigheshill

# Base folder for one exported Instagram account
ACCOUNT_EXPORT_DIR=JSON/theoak.tigheshill

# Path to Meta export posts JSON (relative to working directory)
POSTS_FILE=${ACCOUNT_EXPORT_DIR}/your_instagram_activity/media/posts_1.json

# Root folder of the Meta export — leave blank to auto-detect from POSTS_FILE
EXPORT_ROOT=

# File used to track upload progress across restarts
PROGRESS_FILE=progress.json

# Session cache file used to reuse trusted Instagram login state
SESSION_FILE=session_theoakth.json

# Set to true to validate JSON and print a schedule report without posting
DRY_RUN=false

# Fail-fast behavior: if true, stop script when any enabled feature fails.
# If false, a failing feature is logged and remaining enabled features continue.
STOP_ON_FEATURE_ERROR=false

# Core feature toggles
MIGRATE_FEED_POSTS=true
MIGRATE_REPOSTS=false
MIGRATE_ARCHIVED_POSTS=false
MIGRATE_IGTV=false
MIGRATE_STORIES=false
MIGRATE_PROFILE=false
MIGRATE_FOLLOWING=false

# Best-effort comment replay onto migrated posts (uses comment timestamps)
REPLAY_COMMENTS=false
COMMENT_WINDOW_DAYS=14

# Following replay throttle/safety
FOLLOW_MAX_PER_RUN=50
FOLLOW_SLEEP_SECONDS=2.0

# Optional explicit paths (defaults are already set in script)
COMMENTS_FILE=${ACCOUNT_EXPORT_DIR}/your_instagram_activity/comments/post_comments_1.json
REPOSTS_FILE=${ACCOUNT_EXPORT_DIR}/your_instagram_activity/media/reposts.json
ARCHIVED_POSTS_FILE=${ACCOUNT_EXPORT_DIR}/your_instagram_activity/media/archived_posts.json
IGTV_FILE=${ACCOUNT_EXPORT_DIR}/your_instagram_activity/media/igtv_videos.json
STORIES_FILE=${ACCOUNT_EXPORT_DIR}/your_instagram_activity/media/stories.json
PROFILE_INFO_FILE=${ACCOUNT_EXPORT_DIR}/personal_information/personal_information/personal_information.json
PROFILE_PHOTOS_FILE=${ACCOUNT_EXPORT_DIR}/your_instagram_activity/media/profile_photos.json
FOLLOWING_FILE=${ACCOUNT_EXPORT_DIR}/connections/followers_and_following/following.json

# How many posts to upload per day
POSTS_PER_DAY=25

# Daily posting window (24-h local time)
START_HOUR=8
END_HOUR=22